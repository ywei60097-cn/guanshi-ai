.top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 54rpx; }
.date, .transit { display: block; }
.date { color: #8d9aa9; font-size: 20rpx; letter-spacing: 3rpx; }
.transit { margin-top: 10rpx; font-size: 25rpx; }
.profile { width: 70rpx; height: 70rpx; padding: 0; border: 1rpx solid rgba(178,205,213,.35); border-radius: 50%; color: #58f6c5; background: transparent; line-height: 66rpx; }
.loading { color: #8d9aa9; }
.core { border: 1rpx solid rgba(178,205,213,.35); background: rgba(13,20,36,.78); }
.core-label { display: block; padding: 24rpx 24rpx 0; color: #58f6c5; font-size: 18rpx; letter-spacing: 3rpx; }
.core-main { display: flex; gap: 26rpx; padding: 36rpx 24rpx; }
.orbit { display: flex; flex: 0 0 150rpx; align-items: center; justify-content: center; flex-direction: column; height: 150rpx; border: 1rpx dashed #58f6c5; border-radius: 50%; color: #8d9aa9; font-size: 16rpx; }
.day-master { color: #58f6c5; font-family: "STSong", serif; font-size: 65rpx; font-weight: 300; }
.element { font-size: 18rpx; }
.core-copy { flex: 1; min-width: 0; }
.core-copy .eyebrow { margin-bottom: 10rpx; font-size: 17rpx; }
.core-copy .title { display: block; font-family: "STSong", serif; font-size: 43rpx; line-height: 1.2; }
.core-copy > text:last-child { display: block; margin-top: 15rpx; color: #8d9aa9; font-size: 21rpx; line-height: 1.7; }
.metrics { display: flex; padding: 20rpx 24rpx; border-top: 1rpx solid rgba(178,205,213,.2); }
.metrics > text { flex: 1; color: #8d9aa9; font-size: 19rpx; }
.metric-value { display: block; margin-top: 8rpx; color: #e9f3ee; font-size: 25rpx; font-weight: 400; }
.ask-panel { margin-top: 54rpx; padding: 30rpx 0 4rpx; border-top: 1rpx solid rgba(88,246,197,.45); border-bottom: 1rpx solid rgba(178,205,213,.18); }
.ask-heading { margin-top: 0; }
.ask-lead { color: #8d9aa9; font-size: 24rpx; line-height: 1.75; }
.question-list { margin-top: 24rpx; }
.question { display: flex; justify-content: space-between; gap: 18rpx; padding: 24rpx 0; border-top: 1rpx solid rgba(178,205,213,.16); color: #e9f3ee; font-size: 25rpx; line-height: 1.55; }
.question text { color: #58f6c5; }
.ask-free { margin-top: 24rpx; padding: 0; color: #58f6c5; background: transparent; font-size: 24rpx; text-align: left; line-height: 76rpx; letter-spacing: 2rpx; }
.ask-free text { float: right; font-size: 30rpx; }
.heading { display: flex; justify-content: space-between; margin: 52rpx 0 26rpx; font-family: "STSong", serif; font-size: 37rpx; }
.heading-meta { color: #8d9aa9; font-family: sans-serif; font-size: 17rpx; letter-spacing: 2rpx; }
.scenes { display: grid; grid-template-columns: repeat(2, 1fr); border-top: 1rpx solid rgba(178,205,213,.36); border-left: 1rpx solid rgba(178,205,213,.18); }
.scene { position: relative; min-height: 176rpx; padding: 27rpx 24rpx; border-right: 1rpx solid rgba(178,205,213,.18); border-bottom: 1rpx solid rgba(178,205,213,.18); }
.scene > text:first-child { display: block; color: #8d9aa9; font-size: 16rpx; }
.scene-title { display: block; margin-top: 28rpx; font-family: "STSong", serif; font-size: 37rpx; font-weight: 300; }
.scene-arrow { position: absolute; right: 22rpx; bottom: 18rpx; color: #58f6c5; }
.trace { margin-top: 47rpx; padding-bottom: 13rpx; border-bottom: 1rpx solid #58f6c5; font-size: 25rpx; }
.trace > text:first-child, .trace-arrow { color: #58f6c5; }
.trace > text:first-child { margin-right: 14rpx; font-size: 17rpx; letter-spacing: 2rpx; }
.trace-arrow { float: right; font-size: 32rpx; }

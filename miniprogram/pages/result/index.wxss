.result-title { display: flex; justify-content: space-between; gap: 24rpx; margin-top: 62rpx; }.result-title .display { color: #58f6c5; font-size: 62rpx; }.sigil { display: flex; align-items: center; justify-content: center; flex: 0 0 80rpx; height: 80rpx; border: 1rpx solid #58f6c5; border-radius: 50%; color: #58f6c5; font-family: "STSong", serif; font-size: 38rpx; }.intro { display: block; margin-top: 42rpx; font-size: 30rpx; line-height: 1.95; }.group { padding: 35rpx 0; border-bottom: 1rpx solid rgba(178,205,213,.18); color: #8d9aa9; font-size: 25rpx; line-height: 1.9; }.group > text { display: block; margin-bottom: 18rpx; color: #58f6c5; font-size: 19rpx; letter-spacing: 3rpx; }.item { margin-top: 12rpx; }.rank { display: flex; gap: 24rpx; padding: 20rpx 0; border-top: 1rpx solid rgba(178,205,213,.18); }.rank-index { color: #58f6c5; font-size: 20rpx; }.rank-title, .rank-reason { display: block; }.rank-title { color: #e9f3ee; font-weight: 400; }.rank-reason { color: #8d9aa9; font-size: 21rpx; }.trace-source { margin-bottom: 12rpx; color: #58f6c5; font-size: 21rpx; }.reason { margin-top: 45rpx; padding-bottom: 12rpx; border-bottom: 1rpx solid #58f6c5; font-size: 25rpx; }.reason > text:first-child, .reason-arrow { color: #58f6c5; }.reason > text:first-child { margin-right: 16rpx; font-size: 18rpx; letter-spacing: 2rpx; }.reason-arrow { float: right; font-size: 32rpx; }

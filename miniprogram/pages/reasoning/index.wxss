.summary { display: grid; grid-template-columns: repeat(2, 1fr); gap: 36rpx 24rpx; margin-top: 52rpx; padding: 30rpx 0; border-top: 1rpx solid rgba(178,205,213,.32); border-bottom: 1rpx solid rgba(178,205,213,.18); }.summary > view > text:first-child, .order > text, .limits > text { display: block; margin-bottom: 12rpx; color: #8d9aa9; font-size: 17rpx; letter-spacing: 2rpx; }.summary-value { color: #58f6c5; font-size: 24rpx; font-weight: 400; line-height: 1.45; }.order { padding: 30rpx 0; border-bottom: 1rpx solid rgba(178,205,213,.18); color: #8d9aa9; font-size: 23rpx; line-height: 1.8; }.order > text { color: #58f6c5; }.steps { padding-top: 38rpx; }.step { display: grid; grid-template-columns: 56rpx 1fr; gap: 20rpx; padding-bottom: 42rpx; }.number { display: flex; align-items: center; justify-content: center; width: 42rpx; height: 42rpx; border: 1rpx solid #58f6c5; border-radius: 50%; color: #58f6c5; font-size: 17rpx; }.id, .fact, .inference { display: block; }.id { color: #58f6c5; font-size: 17rpx; line-height: 1.6; }.fact { margin-top: 13rpx; font-size: 26rpx; line-height: 1.8; }.inference { margin-top: 10rpx; color: #8d9aa9; font-size: 23rpx; line-height: 1.85; }.limits { padding: 32rpx 0; border-top: 1rpx solid rgba(178,205,213,.18); color: #8d9aa9; font-size: 22rpx; line-height: 1.9; }.limits > text { color: #58f6c5; }.limits view { margin-top: 12rpx; }

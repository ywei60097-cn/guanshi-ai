.list { margin-top: 56rpx; border-top: 1rpx solid rgba(178,205,213,.32); }.list > view { display: flex; justify-content: space-between; gap: 30rpx; padding: 30rpx 0; border-bottom: 1rpx solid rgba(178,205,213,.18); }.list > view > text:first-child { color: #8d9aa9; font-size: 23rpx; }.value { max-width: 62%; color: #e9f3ee; font-size: 23rpx; font-weight: 400; line-height: 1.65; text-align: right; }.notice { margin-top: 43rpx; padding-top: 28rpx; border-top: 1rpx solid rgba(178,205,213,.18); color: #8d9aa9; font-size: 22rpx; line-height: 1.85; }.notice text { display: block; margin-bottom: 12rpx; color: #58f6c5; font-size: 19rpx; letter-spacing: 2rpx; }.delete { margin-top: 34rpx; padding: 0; color: #ff9db2; background: transparent; font-size: 24rpx; text-align: left; }

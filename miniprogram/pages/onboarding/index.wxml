<view class="page onboarding">
  <text class="core-label">● BAZI CORE · v0.2</text>
  <text class="eyebrow">观时 / DAILY DIVINATION SYSTEM</text>
  <text class="display">用一张命盘，\n读取今天的节奏。</text>
  <text class="lead">按节气排盘，并以月令、格局候选、调候、旺衰的顺序推演。每一步都可查看。</text>

  <view class="form">
    <view class="field"><text>01 / 出生日期</text><picker mode="date" value="{{birthDate}}" bindchange="bindDate"><view>{{birthDate}}</view></picker></view>
    <view class="field"><text>02 / 出生时间</text><picker wx:if="{{timeKnown}}" mode="time" value="{{birthTime}}" bindchange="bindTime"><view>{{birthTime}}</view></picker><view wx:else class="unknown-time">未知（不纳入时柱）</view><view class="time-switch"><text>时辰已知</text><switch checked="{{timeKnown}}" color="#58f6c5" bindchange="bindTimeKnown" /></view></view>
    <view class="field"><text>03 / 出生地</text><input value="{{birthPlace}}" placeholder="例如：杭州" placeholder-class="placeholder" bindinput="bindPlace" /></view>
    <view class="field"><text>04 / 子时换日</text><picker range="{{boundaries}}" value="{{boundaryIndex}}" bindchange="bindBoundary"><view>{{boundaries[boundaryIndex]}}</view></picker></view>
  </view>
  <button class="launch" bindtap="submit">启动命盘引擎 <text>→</text></button>
  <text class="footer-note">资料仅用于本次命理计算。你可随时在“我的”中删除本地资料。</text>
</view>

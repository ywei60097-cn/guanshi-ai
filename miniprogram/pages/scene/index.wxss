.options, .time { margin-top: 64rpx; padding: 28rpx 0; border-top: 1rpx solid rgba(178,205,213,.3); border-bottom: 1rpx solid rgba(178,205,213,.18); }.options > text, .time > text { display: block; margin-bottom: 24rpx; color: #8d9aa9; font-size: 20rpx; letter-spacing: 2rpx; }.pills { display: flex; flex-wrap: wrap; gap: 16rpx; }.pill { padding: 16rpx 22rpx; border: 1rpx solid rgba(178,205,213,.25); color: #8d9aa9; font-size: 25rpx; }.pill.active { border-color: #58f6c5; color: #58f6c5; background: rgba(88,246,197,.11); }.time { margin-top: 0; border-top: 0; }.time picker { color: #e9f3ee; font-size: 30rpx; }.launch { display: flex; justify-content: space-between; margin-top: 50rpx; padding: 0 30rpx; color: #06110f; background: #58f6c5; font-size: 28rpx; line-height: 100rpx; }

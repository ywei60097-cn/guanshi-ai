page {
  background: #060812;
  color: #e9f3ee;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button { border-radius: 0; }
button::after { border: 0; }
.page { min-height: 100vh; padding: 64rpx 48rpx 176rpx; background-image: linear-gradient(rgba(139,165,177,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(139,165,177,.05) 1px, transparent 1px); background-size: 48rpx 48rpx; }
.eyebrow { margin: 0 0 20rpx; color: #58f6c5; font-size: 20rpx; letter-spacing: 4rpx; }
.display { margin: 0; font-family: "Songti SC", "STSong", serif; font-size: 70rpx; font-weight: 300; line-height: 1.15; letter-spacing: -3rpx; }
.lead { margin: 28rpx 0 0; color: #8d9aa9; font-size: 28rpx; line-height: 1.8; }
.back { padding: 0; color: #8d9aa9; background: transparent; font-size: 25rpx; text-align: left; }
.back::before { margin-right: 12rpx; color: #58f6c5; content: "←"; }
.signal { color: #58f6c5; }
.error { margin-top: 28rpx; padding: 24rpx 0; border-top: 1rpx solid rgba(178,205,213,.28); border-bottom: 1rpx solid rgba(178,205,213,.2); color: #ff9db2; font-size: 26rpx; line-height: 1.7; }
.footer-note { margin-top: 40rpx; color: #536071; font-size: 22rpx; line-height: 1.75; }
